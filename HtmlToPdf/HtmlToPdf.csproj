<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>HtmlToPdf</PackageId>
    <VersionPrefix>0.1.0</VersionPrefix>
    <Authors>javaChip56</Authors>
    <Description>HTML to PDF conversion for .NET with a lightweight renderer and an optional Playwright-powered Chromium renderer.</Description>
    <PackageTags>html;pdf;dotnet;playwright</PackageTags>
    <RepositoryUrl>https://github.com/javaChip56/html-to-pdf-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/javaChip56/html-to-pdf-dotnet</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Playwright" Version="1.55.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
